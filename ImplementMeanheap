import java.util.ArrayList;

class Solution {
    private ArrayList<Integer> heap;

    // Initialize the heap
    public void initializeHeap() {
        heap = new ArrayList<>();
    }

    // Insert value x to the min heap
    public void insert(int key) {
        heap.add(key);
        upHeapify(heap.size() - 1);
    }

    // Update the value at given 0-based index to newVal
    public void changeKey(int index, int newVal) {
        if (index < 0 || index >= heap.size()) {
            return;
        }
        
        int oldVal = heap.get(index);
        heap.set(index, newVal);
        
        // Restore heap property based on whether the value decreased or increased
        if (newVal < oldVal) {
            upHeapify(index);
        } else {
            downHeapify(index);
        }
    }

    // Remove the minimum element from the heap
    public void extractMin() {
        if (isEmpty()) {
            return;
        }
        
        // Swap root with the last element
        int lastIdx = heap.size() - 1;
        heap.set(0, heap.get(lastIdx));
        heap.remove(lastIdx);
        
        // Push the root down to its correct position
        if (!heap.isEmpty()) {
            downHeapify(0);
        }
    }

    // Returns true if heap is empty, else false
    public boolean isEmpty() {
        return heap.isEmpty();
    }

    // Output the minimum value from min heap
    public int getMin() {
        if (isEmpty()) {
            return -1; // Fallback if called on an empty heap
        }
        return heap.get(0);
    }

    // Return the current size of the heap
    public int heapSize() {
        return heap.size();
    }

    // Helper method to bubble up an element
    private void upHeapify(int idx) {
        while (idx > 0) {
            int parentIdx = (idx - 1) / 2;
            if (heap.get(idx) < heap.get(parentIdx)) {
                swap(idx, parentIdx);
                idx = parentIdx;
            } else {
                break;
            }
        }
    }

    // Helper method to push down an element
    private void downHeapify(int idx) {
        int n = heap.size();
        while (idx < n) {
            int leftChild = 2 * idx + 1;
            int rightChild = 2 * idx + 2;
            int smallest = idx;

            if (leftChild < n && heap.get(leftChild) < heap.get(smallest)) {
                smallest = leftChild;
            }
            if (rightChild < n && heap.get(rightChild) < heap.get(smallest)) {
                smallest = rightChild;
            }

            if (smallest != idx) {
                swap(idx, smallest);
                idx = smallest;
            } else {
                break;
            }
        }
    }

    // Helper method to swap two elements in the arraylist
    private void swap(int i, int j) {
        int temp = heap.get(i);
        heap.set(i, heap.get(j));
        heap.set(j, temp);
    }
}

import java.util.*;

class Solution {
    public List<Integer> leaders(int[] nums) {
        List<Integer> result = new ArrayList<>();
        int n = nums.length;
        
        // 1. The rightmost element is always a leader
        int maxFromRight = nums[n - 1];
        result.add(maxFromRight);

        // 2. Iterate backwards from the second-to-last element
        for (int i = n - 2; i >= 0; i--) {
            // Only add if it's strictly greater than everything to its right
            if (nums[i] > maxFromRight) {
                result.add(nums[i]);
                maxFromRight = nums[i]; // Update the new maximum
            }
        }

        // 3. Since we added them right-to-left, reverse to restore original order
        Collections.reverse(result);
        return result;
    }
}

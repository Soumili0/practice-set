
import java.util.*;

class Node{
    int data;
    Node next;

Node(int new_data){
    this.data = new_data;
    this.next=null;
}
}
class Main {
    public static void main(String[] args) {
        //System.out.println("Try programiz.pro");
        Node head = new Node(10);
        head.next=new Node(20);
        head.next.next=new Node(30);
        head.next.next.next=new Node(40);
        Node temp = head;
        while(temp !=null){
            System.out.print(temp.data+"  ");
            temp=temp.next;
        }

    }
}
